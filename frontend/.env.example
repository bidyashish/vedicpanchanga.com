# Backend API origin. Leave empty in production if Nginx serves /api on same origin.
VITE_BACKEND_URL=http://localhost:8001

# Public-facing contact addresses shown in the footer and legal pages.
# Defaults to support@vedicpanchanga.com / contact@vedicpanchanga.com if unset.
VITE_SUPPORT_EMAIL=support@vedicpanchanga.com
VITE_CONTACT_EMAIL=contact@vedicpanchanga.com

# Google AdSense (optional). Unset = placeholders shown in place of ads.
# VITE_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
# VITE_ADSENSE_SLOT_HEADER=1111111111
# VITE_ADSENSE_SLOT_SIDEBAR=2222222222
# VITE_ADSENSE_SLOT_INLINE=3333333333
# VITE_ADSENSE_SLOT_FOOTER=4444444444
